{
  "name": "@watchdog/backend",
  "version": "0.0.1",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r dotenv/config src/index.ts dotenv_config_path=../../.env",
    "worker": "ts-node-dev --respawn --transpile-only -r dotenv/config src/worker.ts dotenv_config_path=../../.env",
    "build": "tsc && esbuild src/scripts/agent-runner.ts --bundle --platform=node --target=node18 --outfile=dist/agent-runner.bundle.js",
    "build:bundle": "esbuild src/scripts/agent-runner.ts --bundle --platform=node --target=node18 --outfile=dist/agent-runner.bundle.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "ts-node src/db/seed.ts",
    "mock-webhook": "ts-node src/scripts/mock-webhook.ts",
    "agent-runner": "ts-node src/scripts/agent-runner.ts",
    "demo-app": "ts-node src/scripts/demo-app.ts",
    "check": "ts-node src/scripts/health-check.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "@types/bcryptjs": "^2.4.6",
    "@watchdog/shared-types": "*",
    "axios": "^1.7.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "concurrently": "10.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "lighthouse": "^13.4.1",
    "node-cron": "^4.2.1",
    "otplib": "^12.0.1",
    "playwright": "^1.60.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^6.0.0",
    "resend": "^6.12.4",
    "web-push": "^3.6.7",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.4",
    "esbuild": "^0.28.1",
    "jest": "^29.7.0",
    "prisma": "^5.13.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "ts-node src/db/seed.ts"
  }
}
