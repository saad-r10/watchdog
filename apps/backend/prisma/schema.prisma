generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String
  name             String
  emailVerified    Boolean  @default(false)
  alertEmail       String?
  alertDowntime    Boolean  @default(true)
  alertSslExpiry   Boolean  @default(true)
  alertCertTransparency Boolean @default(true)
  alertBlocklist   Boolean  @default(true)
  alertContentChange Boolean @default(true)
  webhookUrl       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  monitors                  Monitor[]
  alerts                    Alert[]
  agents                    Agent[]
  statusPages               StatusPage[]
  passwordResetTokens       PasswordResetToken[]
  emailVerificationTokens   EmailVerificationToken[]
}

model Agent {
  id         String    @id @default(uuid())
  userId     String
  name       String
  keyHash    String    @unique
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  monitors Monitor[]
}

model Monitor {
  id              String   @id @default(uuid())
  userId          String
  agentId         String?
  name            String
  url             String
  intervalMinutes Int      @default(5)
  isActive        Boolean  @default(true)
  paused          Boolean  @default(false)
  contentChangeEnabled     Boolean   @default(false)
  contentChangeSnoozeUntil DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent       Agent?              @relation(fields: [agentId], references: [id], onDelete: SetNull)
  checks              Check[]
  incidents           Incident[]
  statusPages         StatusPageMonitor[]
  maintenanceWindows  MaintenanceWindow[]
  certificates        MonitorCertificate[]
}

model Check {
  id           String   @id @default(uuid())
  monitorId    String
  type         CheckType
  status       String
  statusCode   Int?
  responseTime Int?
  dnsMs        Int?
  tcpMs        Int?
  tlsMs        Int?
  ttfbMs       Int?
  downloadMs   Int?
  sizeBytes    Int?
  sslDaysLeft  Int?
  headers      Json?
  ctNewCerts   Json?
  dnsFindings  Json?
  exposureFindings Json?
  blocklistFindings Json?
  contentHash  String?
  metricName   String?
  metricValue  Float?
  checkedAt    DateTime @default(now())

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
}

model Incident {
  id          String    @id @default(uuid())
  monitorId   String
  type        IncidentType
  startedAt   DateTime  @default(now())
  resolvedAt  DateTime?
  isResolved  Boolean   @default(false)

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  alerts  Alert[]
}

model Alert {
  id         String   @id @default(uuid())
  userId     String
  incidentId String
  channel    String   @default("email")
  type       String   @default("downtime")
  sentAt     DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

model StatusPage {
  id        String   @id @default(uuid())
  userId    String
  slug      String   @unique
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  monitors StatusPageMonitor[]
}

model StatusPageMonitor {
  statusPageId String
  monitorId    String

  statusPage StatusPage @relation(fields: [statusPageId], references: [id], onDelete: Cascade)
  monitor    Monitor    @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@id([statusPageId, monitorId])
}

model MaintenanceWindow {
  id          String   @id @default(uuid())
  monitorId   String
  startsAt    DateTime
  endsAt      DateTime
  description String?
  createdAt   DateTime @default(now())

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
}

model MonitorCertificate {
  id          String   @id @default(uuid())
  monitorId   String
  crtShId     String
  commonName  String
  issuerName  String
  nameValue   String
  notBefore   DateTime
  notAfter    DateTime
  firstSeenAt DateTime @default(now())

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@unique([monitorId, crtShId])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum CheckType {
  uptime
  ssl
  headers
  metric
  cert_transparency
  dns
  exposure
  blocklist
}

enum IncidentType {
  downtime
  ssl_expiry
  header_missing
  unexpected_cert
  domain_blocklisted
  content_changed
}
