generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String
  name             String
  alertEmail       String?
  alertDowntime    Boolean  @default(true)
  alertSslExpiry   Boolean  @default(true)
  webhookUrl       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  monitors     Monitor[]
  alerts       Alert[]
  agents       Agent[]
  statusPages  StatusPage[]
}

model Agent {
  id         String    @id @default(uuid())
  userId     String
  name       String
  keyHash    String    @unique
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  monitors Monitor[]
}

model Monitor {
  id              String   @id @default(uuid())
  userId          String
  agentId         String?
  name            String
  url             String
  intervalMinutes Int      @default(5)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent       Agent?              @relation(fields: [agentId], references: [id], onDelete: SetNull)
  checks              Check[]
  incidents           Incident[]
  statusPages         StatusPageMonitor[]
  maintenanceWindows  MaintenanceWindow[]
}

model Check {
  id           String   @id @default(uuid())
  monitorId    String
  type         CheckType
  status       String
  statusCode   Int?
  responseTime Int?
  sslDaysLeft  Int?
  headers      Json?
  metricName   String?
  metricValue  Float?
  checkedAt    DateTime @default(now())

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
}

model Incident {
  id          String    @id @default(uuid())
  monitorId   String
  type        IncidentType
  startedAt   DateTime  @default(now())
  resolvedAt  DateTime?
  isResolved  Boolean   @default(false)

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  alerts  Alert[]
}

model Alert {
  id         String   @id @default(uuid())
  userId     String
  incidentId String
  channel    String   @default("email")
  sentAt     DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

model StatusPage {
  id        String   @id @default(uuid())
  userId    String
  slug      String   @unique
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  monitors StatusPageMonitor[]
}

model StatusPageMonitor {
  statusPageId String
  monitorId    String

  statusPage StatusPage @relation(fields: [statusPageId], references: [id], onDelete: Cascade)
  monitor    Monitor    @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@id([statusPageId, monitorId])
}

model MaintenanceWindow {
  id          String   @id @default(uuid())
  monitorId   String
  startsAt    DateTime
  endsAt      DateTime
  description String?
  createdAt   DateTime @default(now())

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
}

enum CheckType {
  uptime
  ssl
  headers
  metric
}

enum IncidentType {
  downtime
  ssl_expiry
  header_missing
}
