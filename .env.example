# Database
DATABASE_URL="postgresql://watchdog:watchdog@localhost:5432/watchdog_dev"

# Auth
JWT_SECRET="change-me-in-production"

# Resend (https://resend.com — get a free API key)
RESEND_API_KEY=""
ALERT_FROM_EMAIL="alerts@yourdomain.com"

# App
PORT="3001"
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# Synthetic monitoring (Playwright-based multi-step checks) — resource-intensive, off by default
SYNTHETIC_MONITORING_ENABLED="false"

# Lighthouse CI monitoring (headless Chrome via Playwright, daily) — resource-intensive, off by default
LIGHTHOUSE_MONITORING_ENABLED="false"

# Web Push (VAPID) — generate keys with: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(JSON.stringify(k,null,2))"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:alerts@yourdomain.com"

# Rate limiting
RATE_LIMIT_AUTH_WINDOW_MS="900000"   # 15 minutes
RATE_LIMIT_AUTH_MAX="20"             # max requests per window on /api/auth/*
RATE_LIMIT_API_WINDOW_MS="60000"     # 1 minute
RATE_LIMIT_API_MAX="120"             # max requests per window on /api/*
