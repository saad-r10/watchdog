# Database
DATABASE_URL="postgresql://watchdog:watchdog@localhost:5432/watchdog_dev"

# Auth
JWT_SECRET="change-me-in-production"

# Resend (https://resend.com — get a free API key)
RESEND_API_KEY=""
ALERT_FROM_EMAIL="alerts@yourdomain.com"

# App
PORT="3001"
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# Synthetic monitoring (Playwright-based multi-step checks) — resource-intensive, off by default
SYNTHETIC_MONITORING_ENABLED="false"

# Lighthouse CI monitoring (headless Chrome via Playwright, daily) — resource-intensive, off by default
LIGHTHOUSE_MONITORING_ENABLED="false"
